# agent-tui Environment Variables Configuration Template
# Copy this file to .env and configure the variables.

# API key for the model provider (Required)
API_KEY=your-api-key-here

# Model name to use (Required, e.g. gpt-4o, gpt-4-turbo, claude-3-5-sonnet-20240620)
MODEL=gpt-4o

# API base URL for OpenAI-compatible providers
# Defaults to https://api.openai.com/v1 if not specified
BASE_URL=https://api.openai.com/v1

# Workspace directory for agent operations
# Defaults to the current working directory if not specified
WORKSPACE=./workspace

# Provider name used by the model adapter (e.g. openai, anthropic, gemini)
# Defaults to "openai"
PROVIDER=openai
